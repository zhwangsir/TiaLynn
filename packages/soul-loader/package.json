{
  "name": "@tialynn/soul-loader",
  "version": "0.1.0",
  "description": "TiaLynn three-layer persona soul config merger + LLM system prompt builder — pure functions, runtime-agnostic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./merger": {
      "types": "./dist/merger.d.ts",
      "import": "./dist/merger.js",
      "require": "./dist/merger.cjs"
    },
    "./system-prompt": {
      "types": "./dist/system-prompt.d.ts",
      "import": "./dist/system-prompt.js",
      "require": "./dist/system-prompt.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "persona",
    "soul",
    "llm",
    "system-prompt",
    "ai-companion",
    "vtuber"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhwangsir/TiaLynn.git",
    "directory": "packages/soul-loader"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
