{
  "name": "@tialynn/motion-factory",
  "version": "0.1.0",
  "description": "Live2D Cubism 4 motion3.json encoder + validator + scorer — pure functions, runtime-agnostic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./encoder": {
      "types": "./dist/encoder.d.ts",
      "import": "./dist/encoder.js",
      "require": "./dist/encoder.cjs"
    },
    "./validator": {
      "types": "./dist/validator.d.ts",
      "import": "./dist/validator.js",
      "require": "./dist/validator.cjs"
    },
    "./scorer": {
      "types": "./dist/scorer.d.ts",
      "import": "./dist/scorer.js",
      "require": "./dist/scorer.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "live2d",
    "cubism",
    "motion3",
    "lipsync",
    "vtuber",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhwangsir/TiaLynn.git",
    "directory": "packages/motion-factory"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
