{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TiaLynn",
  "version": "0.1.0",
  "identifier": "com.tialynn.companion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TiaLynn",
        "width": 480,
        "height": 720,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": false,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": false,
        "x": 80,
        "y": 80
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"]
        }
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "localhost"
    }
  }
}
